{
    "name": "ripplesanalytics/ripples-php",
    "description": "Official PHP SDK for Ripples.sh — server-side event tracking",
    "keywords": ["ripples", "analytics", "tracking", "revenue", "php"],
    "homepage": "https://ripples.sh",
    "license": "MIT",
    "authors": [
        {
            "name": "Ripples Analytics",
            "homepage": "https://ripples.sh"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Ripples\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ripples\\Tests\\": "tests/"
        }
    }
}
